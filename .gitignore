# ─── Данные заказчика — НЕ в публичный репо ───
демо_фото/
data/datasets/
data/*.csv
data/raw/
# сырые папки датасетов лежат вне репо (пути в configs/paths.yaml)

# ─── Локальный архив черновиков — вне публичного репозитория ───
свалка/

# ─── Отчёты (регенерируемое, содержит пути/счётчики данных заказчика) — приватно ───
reports/
# Отчёты/презентации ВКР — приватно (метаданные автора, шаблон ТГУ, данные заказчика)
отчёт_ВКР/
отчёты/
*.pptx
# Временные lock-файлы MS Office
~$*

# ─── Блок 2: изолированный venv для SAM2 (тяжёлое, локальное) ───
tools/

# ─── Веса, индексы, кропы (тяжёлое/регенерируемое) ───
*.pt
*.pth
*.onnx
*.npy
# artifacts приватны, кроме сводки sealed-метрик (только агрегированные числа, без данных заказчика);
# негация не работает под игнорируемой директорией — поэтому artifacts/*, а не artifacts/
artifacts/*
!artifacts/ab_test_headline.json
crops_*/
runs/
*.zip

# ─── Материалы: транскрипты, статьи (копирайт) — приватно ───
материалы/
*.pdf
*.docx

# ─── Приватные рабочие заметки и локальная конфигурация — не в публичный репо ───
# Остаются на диске для работы; публичные деливераблы (чистый ТЗ/текст НИР) добавляются отдельно.
docs/
# Личные пути/имена папок заказчика; публичный шаблон — configs/paths.example.yaml
configs/paths.yaml

# ─── Видео/аудио ───
*.mp4
*.webm
*.mp3
*.mov

# ─── Python / ОС / IDE ───
__pycache__/
*.egg-info/
*.py[cod]
.pytest_cache/
.ipynb_checkpoints/
.venv/
venv/
env/
.DS_Store
.idea/
.vscode/

# ─── В корне публичен только README; прочие корневые заметки и служебные папки — локальные ───
/*.md
!/README.md
!/THIRD_PARTY_NOTICES.md
!/CHANGELOG.md
/.*/
!/.github/
